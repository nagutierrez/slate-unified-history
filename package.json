{
  "name": "slate-unified-history",
  "version": "0.1.2",
  "description": "Slate history with pluggable unified undo/redo (Slate batches + custom commands).",
  "author": "Nathan Gutierrez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nagutierrez/slate-unified-history.git"
  },
  "bugs": {
    "url": "https://github.com/nagutierrez/slate-unified-history/issues"
  },
  "homepage": "https://github.com/nagutierrez/slate-unified-history#readme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "slate": ">=0.114.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vitest": "^0.5.4",
    "prettier": "^3.8.1",
    "slate": "^0.124.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "editor",
    "history",
    "slate",
    "undo",
    "redo"
  ]
}
